{
  "name": "bluff-call",
  "version": "1.0.0",
  "private": true,
  "description": "Play Kuhn poker against its solved equilibrium and see the optimal move after every hand.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ctkrug/bluff-call.git"
  },
  "keywords": [
    "kuhn-poker",
    "game-theory",
    "nash-equilibrium",
    "game"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run tests/game --coverage --coverage.include='src/game/**/*.ts' --pool=forks --maxWorkers=1",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^8.57.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.5.4",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
